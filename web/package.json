{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bun run typecheck && bun vite build --mode production",
    "preview": "bunx --bun vite preview --port 4173",
    "typecheck": "bun vue-tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,scss}\"",
    "update": "bun update --latest"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@types/nprogress": "^0.2.3",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "signature_pad": "^5.1.3",
    "uuid": "^14.0.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "expr-eval": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/vite": "^4.2.2",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.0",
    "@vitest/ui": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}